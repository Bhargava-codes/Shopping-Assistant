OPENROUTER_API_KEY=sk-or-v1-...
# Playground and benchmark run on the same pinned, latest model so the score
# cannot be moved by swapping models.
OPENROUTER_MODEL=google/gemini-3.1-flash-lite
# The score of record uses this fixed model. Do not change it during the exercise.
BENCHMARK_MODEL=google/gemini-3.1-flash-lite
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_NAME=Shopping Agent Lab
